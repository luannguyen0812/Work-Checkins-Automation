# Telegram
TELEGRAM_BOT_TOKEN=           # From @BotFather
TELEGRAM_GROUP_CHAT_ID=       # Negative integer for group chats
ADMIN_TELEGRAM_USER_ID=       # Your personal Telegram numeric ID

# Google Sheets
GOOGLE_SHEETS_SPREADSHEET_ID= # From the sheet URL
GOOGLE_SERVICE_ACCOUNT_JSON=  # Path to service account key file

# Admin API
ADMIN_API_SECRET=             # Bearer token for /config and /report/run endpoints
ADMIN_API_PORT=5050
FLASK_ENABLED=true            # Set to false when running the dashboard as a separate
                               # gunicorn process (deploy/vps path) -- otherwise main.py
                               # also starts its own embedded Flask server on the same port

# Email (optional — Telegram DM is primary)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=                # App password, not account password
REPORT_RECIPIENT_EMAIL=luan.nguyen@intrastack.com

# Claude API — used for the weekly report's executive summary narrative, AND for
# parsing freeform schedule text into structured JSON (self-registration + the
# nightly Team Members sync in scripts/parse_schedules.py). Without this set,
# both features degrade gracefully (plain-text narrative, unparsed schedules)
# rather than failing.
ANTHROPIC_API_KEY=            # sk-ant-...
CLAUDE_SUMMARY_MODEL=claude-haiku-4-5-20251001

# Timezone
TZ=America/New_York
